# ─── PISTE (Plateforme d'Intermédiation des Services Technologiques de l'État) ───
# Créez votre compte sur https://piste.gouv.fr et enregistrez votre application
# pour obtenir vos clés OAuth2.

# Judilibre (Cour de cassation)
PISTE_CLIENT_ID=votre_client_id_ici
PISTE_CLIENT_SECRET=votre_client_secret_ici

# Légifrance (DILA) — utilise les mêmes identifiants PISTE
# Décommentez si vous avez un client_id/secret distinct pour Légifrance
# LEGIFRANCE_CLIENT_ID=votre_client_id_legifrance
# LEGIFRANCE_CLIENT_SECRET=votre_client_secret_legifrance

# ─── Comportement de l'application ────────────────────────────────────────────
# "live"   → appels réels aux API PISTE (nécessite des clés valides)
# "mock"   → données de démonstration uniquement
# "hybrid" → API réelle avec fallback sur mock en cas d'erreur (recommandé en dev)
DATA_MODE=hybrid

# ─── IA / RAG ─────────────────────────────────────────────────────────────────
# Clé API pour le modèle de génération (Claude via Anthropic)
ANTHROPIC_API_KEY=votre_cle_anthropic_ici

# ─── Sécurité interne ─────────────────────────────────────────────────────────
# Clé secrète pour signer les sessions (générer avec : openssl rand -base64 32)
NEXTAUTH_SECRET=changer_cette_valeur_en_production
NEXTAUTH_URL=http://localhost:3000
